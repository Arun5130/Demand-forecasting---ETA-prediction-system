# Application identity and runtime
APP_NAME=delivery-ml-platform
APP_ENVIRONMENT=development
APP_VERSION=0.1.0
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_FORMAT=json

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=delivery_ml
POSTGRES_USER=delivery_ml
POSTGRES_PASSWORD=change-me-before-deployment
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT_SECONDS=30
POSTGRES_POOL_RECYCLE_SECONDS=1800
POSTGRES_CONNECT_TIMEOUT_SECONDS=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SOCKET_TIMEOUT_SECONDS=3
REDIS_FEATURE_TTL_SECONDS=3600
REDIS_WEATHER_TTL_SECONDS=1800

# ML artifacts and runtime
MODEL_ARTIFACTS_DIRECTORY=artifacts
MODEL_REGISTRY_STAGE=production
RANDOM_SEED=42
INFERENCE_MAX_BATCH_SIZE=1000

# Scheduler
RETRAIN_SCHEDULE_DAY_OF_WEEK=sunday
RETRAIN_SCHEDULE_HOUR_UTC=2
RETRAIN_SCHEDULE_MINUTE_UTC=0
